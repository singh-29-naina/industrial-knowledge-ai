# Dependencies
node_modules/
**/node_modules/

# Environment variables — never commit real secrets
.env
.env.local
.env.*.local
**/.env

# Build outputs
dist/
build/
**/dist/
**/build/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/

# Vector DB local storage — regenerated on ingestion, shouldn't be versioned
chroma_db/
**/chroma_db/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json
.idea/

# Uploaded/temp files if ever written to disk
/uploads/
/tmp/

# Test/coverage
coverage/
.nyc_output/